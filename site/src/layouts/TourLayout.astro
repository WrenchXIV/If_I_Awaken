---
import '@/styles/global.css';
import SiteHeader from '@/components/SiteHeader.astro';
import EditorOverlay from '@/components/EditorOverlay.astro';

export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description = '', bodyClass = '' } = Astro.props;
---

<!doctype html>
<html lang="en" data-brand="cinema">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#F4EFE6" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.svg`.replace('//', '/')} />
  </head>
  <body class={`bg-paper text-ink ${bodyClass}`}>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <EditorOverlay />
    <script>
      // Reveal-on-scroll: fade beats and other [.reveal] elements as they enter the viewport.
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
