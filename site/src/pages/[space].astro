---
import TourLayout from '@/layouts/TourLayout.astro';
import Hero from '@/components/Hero.astro';
import Callout from '@/components/Callout.astro';
import MetaRow from '@/components/MetaRow.astro';
import PlanView from '@/components/PlanView.astro';
import PerspectiveGallery from '@/components/PerspectiveGallery.astro';
import BeatSequence from '@/components/BeatSequence.astro';
import DesignState from '@/components/DesignState.astro';
import SpaceFooter from '@/components/SpaceFooter.astro';
import AudioPlayer from '@/components/AudioPlayer.astro';
import { SPACE_ORDER } from '@/lib/spaces';
import { getSpace } from '@/lib/content';
import type { SpaceContent } from '@/types';

export function getStaticPaths() {
  return SPACE_ORDER.map((id) => ({
    params: { space: id },
    props: { space: getSpace(id) },
  }));
}

interface Props {
  space: SpaceContent;
}

const { space } = Astro.props as Props;
const pageTitle = `${space.title} — If I Awaken in Los Angeles`;
---

<TourLayout title={pageTitle} description={(space.summary ?? '').replace(/<[^>]+>/g, '').slice(0, 200)}>
  <Hero space={space} />
  <Callout summary={space.summary} callout={space.callout} />
  {space.meta && space.meta.length > 0 && <MetaRow meta={space.meta} />}
  {space.plan && <PlanView plan={space.plan} index={space.index} />}
  {space.perspectives && space.perspectives.length > 0 && (
    <PerspectiveGallery images={space.perspectives} />
  )}
  {space.beats && space.beats.length > 0 && <BeatSequence beats={space.beats} />}
  {space.design && <DesignState state={space.design} />}
  {space.audio && <AudioPlayer src={space.audio.src} label={space.audio.label} />}
  <SpaceFooter space={space} />
</TourLayout>
