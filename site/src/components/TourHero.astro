---
import type { SpaceContent } from '@/types';

export interface Props {
  space: SpaceContent;
}
const { space } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const heroSrc = space.hero.src.startsWith('http') ? space.hero.src : `${base}${space.hero.src}`;
const pos = space.hero.position ?? '50% 55%';
---

<section
  data-block="tour-hero"
  class="relative isolate w-full overflow-hidden bg-dark-bg text-on-dark"
  style="height: clamp(480px, 78vh, 880px);"
>
  <img
    src={heroSrc}
    alt={space.hero.alt}
    class="absolute inset-0 h-full w-full object-cover"
    style={`object-position: ${pos}; filter: brightness(0.55) contrast(1.05);`}
    loading="eager"
    decoding="async"
  />
  <div
    class="absolute inset-0"
    style="background: linear-gradient(180deg, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0) 32%, rgba(0,0,0,0) 56%, rgba(0,0,0,0.92) 100%);"
  ></div>

  <div class="relative mx-auto flex h-full max-w-[1320px] items-end px-6 py-12 md:px-12 md:py-16">
    <div class="max-w-[24ch]">
      <h1 class="display text-on-dark" style="font-size: clamp(58px, 9vw, 156px);" data-editable>
        {space.title}
      </h1>
      {space.tagline && (
        <p class="lede mt-4 text-on-dark/85" style="font-size: clamp(20px, 2.2vw, 28px);" data-editable>
          — {space.tagline}
        </p>
      )}
    </div>
  </div>
</section>
