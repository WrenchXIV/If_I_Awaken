---
import type { PlanView } from '@/types';

export interface Props {
  plan: PlanView;
  index: number;
}

const { plan, index } = Astro.props;
const sectionLabel = `Section 01 — Plan view`;
---

<section data-block="plan" class="border-b border-[var(--rule)] bg-paper">
  <div class="mx-auto max-w-[1320px] px-6 py-16 md:px-12 md:py-20">
    <header class="mb-10 flex items-end justify-between gap-6 border-b border-[var(--rule)] pb-4">
      <div>
        <span class="kicker">{sectionLabel}</span>
        <h2 class="display mt-2" style="font-size: clamp(34px, 4vw, 56px);" data-editable>
          The plan
        </h2>
      </div>
      <span class="eyebrow hidden md:inline">Top-down architectural view</span>
    </header>

    <div class="grid gap-8 lg:grid-cols-12">
      <div class="lg:col-span-9">
        <div class="blueprint plan-frame relative w-full overflow-hidden rounded-sm">
          <Fragment set:html={plan.svg} />
        </div>
        {plan.caption && (
          <p
            class="mt-4 max-w-prose text-sm text-ink/65"
            style="font-family: var(--f-body);"
            data-editable
          >
            {plan.caption}
          </p>
        )}
      </div>

      {plan.legend && plan.legend.length > 0 && (
        <aside class="lg:col-span-3">
          <span class="eyebrow">Legend</span>
          <ul class="mt-4 space-y-3">
            {plan.legend.map((row) => (
              <li class="flex items-start gap-3">
                <span
                  class="mt-1 inline-block h-3 w-3 flex-shrink-0 rounded-sm"
                  style={`background: ${row.color};`}
                ></span>
                <div>
                  <div class="text-sm font-semibold text-ink" data-editable>{row.label}</div>
                  {row.note && (
                    <div class="text-xs text-ink/60" data-editable>{row.note}</div>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </div>
  </div>
</section>
