---
import type { PerspectiveImage } from '@/types';

export interface Props {
  images: PerspectiveImage[];
}

const { images } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section data-block="perspectives" class="border-b border-[var(--rule)] bg-paper-dim">
  <div class="mx-auto max-w-[1320px] px-6 py-16 md:px-12 md:py-20">
    <header class="mb-10 flex items-end justify-between gap-6 border-b border-[var(--rule)] pb-4">
      <div>
        <span class="kicker">Section 02 — In the room</span>
        <h2 class="display mt-2" style="font-size: clamp(34px, 4vw, 56px);" data-editable>
          What the audience sees
        </h2>
      </div>
      <span class="eyebrow hidden md:inline">Audience perspective</span>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      {images.map((img, i) => {
        const src = img.src.startsWith('http') ? img.src : `${base}${img.src}`;
        return (
          <figure data-block={`perspective-${i}`} class="reveal">
            <div class="relative overflow-hidden bg-dark-bg" style="aspect-ratio: 4 / 3;">
              <img
                src={src}
                alt={img.alt}
                class="h-full w-full object-cover transition-transform duration-700 hover:scale-[1.02]"
                loading="lazy"
                decoding="async"
              />
            </div>
            {img.caption && (
              <figcaption class="mt-3 text-sm text-ink/70" data-editable>
                {img.caption}
              </figcaption>
            )}
          </figure>
        );
      })}
    </div>
  </div>
</section>
